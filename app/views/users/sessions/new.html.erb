<h2 class="text-2xl font-bold text-contentPrimary mb-6">Sign In</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-contentSecondary mb-2" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
        class: "input-base" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-contentSecondary mb-2" %>
    <%= f.password_field :password, autocomplete: "current-password",
        class: "input-base" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center">
      <%= f.check_box :remember_me %>
      <%= f.label :remember_me, class: "ml-2 text-sm text-contentSecondary" %>
    </div>
  <% end %>

  <div>
    <%= f.submit "Sign In", class: "btn-base btn-l btn-default-primary w-full" %>
  </div>
<% end %>

<div class="mt-6 text-center">
  <%= render "users/shared/links" %>
</div>

<% if lookup_context.exists?("users/sessions/oauth_providers", [], true) %>
  <%= render "users/sessions/oauth_providers" %>
<% end %>
