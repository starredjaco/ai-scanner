<%
  attempt = local_assigns[:attempt]
  index = local_assigns[:index] || 0
  report = local_assigns[:report]
  variant_industry = local_assigns[:variant_industry] || nil
  probe_index = local_assigns[:probe_index] || 0
  probe_result_id = local_assigns[:probe_result_id]

  raw_prompt = attempt['prompt'] || attempt[:prompt]
  prompt = TokenEstimator.extract_prompt_text(raw_prompt) || ''
  raw_response = (attempt['outputs'] || attempt[:outputs])&.first
  response = TokenEstimator.extract_output_text(raw_response) || ''
  score = attempt.dig('notes', 'score_percentage')

  is_variant = variant_industry.present?
  unique_attempt_id = "#{probe_index}-#{index}"

  attempt_input_tokens = TokenEstimator.estimate_tokens(prompt)
  attempt_output_tokens = TokenEstimator.estimate_tokens(response)
  attack_successful = score.present? && score.to_f > 0
%>

<div class="w-full font-sans">
  <button class="w-full flex items-center gap-3 cursor-pointer hover:bg-zinc-800/30 rounded-lg transition-colors py-2 px-1"
          data-action="click->report-redesigned#toggleAttemptCard"
          data-attempt-index="<%= unique_attempt_id %>">
    <%# Left side: Attempt label and variant badge %>
    <div class="flex items-center gap-2">
      <span class="text-base text-white font-sans">
        Attempt #<%= index + 1 %>
      </span>
      <% if is_variant %>
        <span class="text-xs text-purple-400 font-sans uppercase tracking-wide ml-4">
          Variant
        </span>
        <span class="bg-purple-950 rounded-md px-2.5 py-0.5 text-xs text-purple-400" title="Industry-specific variant of the probe">
          <%= variant_industry %>
        </span>
      <% end %>
    </div>

    <%# Right side: Status, tokens, and chevron %>
    <div class="flex items-center gap-3 ml-auto">
      <% if score.present? %>
        <% if attack_successful %>
          <span class="bg-red-950 rounded-md px-2.5 py-1 text-xs font-semibold text-red-400 uppercase tracking-wide" title="The probe successfully elicited a vulnerable response from the target model">
            Attack Successful
          </span>
        <% else %>
          <span class="bg-zinc-800 rounded-md px-2.5 py-1 text-xs font-semibold text-zinc-400 uppercase tracking-wide" title="The target model successfully defended against this probe attempt">
            ATTACK FAILED
          </span>
        <% end %>
      <% end %>

      <% if attempt_input_tokens > 0 || attempt_output_tokens > 0 %>
        <span class="text-xs font-sans">
          <span class="text-zinc-500">Tokens:</span>
          <span class="text-white"><%= number_with_delimiter(attempt_input_tokens) %> in / <%= number_with_delimiter(attempt_output_tokens) %> out</span>
        </span>
      <% end %>

      <span class="icon icon-sm icon-chevron-down text-contentTertiary transition-transform duration-200"
            data-report-redesigned-target="attemptChevron"
            data-attempt-index="<%= unique_attempt_id %>"
            style="transform: rotate(0deg)"></span>
    </div>
  </button>

  <div class="hidden pl-4 pb-4 flex-col gap-4"
       data-report-redesigned-target="attemptContent"
       data-attempt-index="<%= unique_attempt_id %>">
    <turbo-frame id="attempt-content-<%= probe_result_id %>-<%= index %>"
                 data-attempt-content-url="<%= attempt_content_report_path(report, probe_result_id: probe_result_id, attempt_index: index) %>"
                 class="flex flex-col gap-4">
      <div class="flex items-center justify-center py-4">
        <span class="text-sm text-contentSecondary font-sans">Loading content...</span>
      </div>
    </turbo-frame>
  </div>
</div>
