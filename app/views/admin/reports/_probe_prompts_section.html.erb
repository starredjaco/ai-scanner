<%
  probe_result = local_assigns[:probe_result]
  report = local_assigns[:report]
  index = local_assigns[:index] || 0
%>

<div class="flex flex-col gap-2">
  <h3 class="text-lg text-white font-sans mb-4">Prompts & Responses</h3>

  <div class="w-full">
    <div class="pl-4 w-full">
      <%= render partial: 'admin/reports/variant_prompts_responses', locals: {
        probe_result: probe_result,
        report: report,
        probe_index: index,
        preloaded: local_assigns[:preloaded]
      } %>
    </div>
  </div>
</div>
