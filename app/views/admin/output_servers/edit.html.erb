<%
  action_buttons = [
    { label: "Delete", path: output_server_path(@output_server), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this integration?" }, variant: :default, color: :gray, size: :base, icon: "icon-trash" }
  ]
%>
<%= render partial: "admin/shared/show_header", locals: { title: "Edit Integration: #{@output_server.name}", action_buttons: action_buttons } %>

<div class="py-6">
  <div class="flex flex-col xl:flex-row gap-6">
    <div class="w-full xl:w-1/2">
      <%= render 'form', output_server: @output_server %>
    </div>
    <div class="w-full xl:w-1/2">
      <%= render 'help_panel' %>
    </div>
  </div>
</div>
