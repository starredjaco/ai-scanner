<%
  # Build action buttons for the header
  action_buttons = [{
    label: "New Metadata",
    path: new_metadatum_path,
    variant: :default,
    color: :primary,
    size: :base
  }]
%>

<%= render partial: "admin/shared/table_header", locals: { title: "Metadata", current_page: :index, action_buttons: action_buttons } %>

<%# Card wrapper for filter panel and table %>
<div class="rounded-lg bg-backgroundPrimary border border-borderPrimary overflow-hidden">
  <%# Filter Panel %>
  <%
    filters = [
      { key: :id, label: "ID", type: :text, placeholder: "Search by ID..." },
      { key: :key, label: "Key", type: :text, placeholder: "Search by key..." },
      { key: :value, label: "Value", type: :text, placeholder: "Search by value..." },
      { key: :created_at, label: "Created", type: :date_range }
    ]
  %>
  <%= render "shared/filter/filter_panel",
      ransack: @q,
      filters: filters,
      form_url: metadata_path %>

<%
  columns = [
    {
      key: :id,
      label: "ID",
      type: :link,
      link_path: ->(metadatum) { metadatum_path(metadatum) },
      link_class: "text-primary hover:underline",
      sortable: true
    },
    {
      key: :key,
      label: "Key",
      type: :code,
      sortable: true
    },
    {
      key: :value,
      label: "Value",
      type: :custom,
      sortable: true,
      render: ->(metadatum) {
        value = metadatum.value.to_s
        if value.length > 50
          content_tag(:code, value.truncate(50), title: value, class: "bg-backgroundSecondary px-2 py-1 rounded text-sm cursor-help")
        else
          content_tag(:code, value, class: "bg-backgroundSecondary px-2 py-1 rounded text-sm")
        end
      }
    },
    {
      key: :created_at,
      label: "Created On",
      type: :datetime,
      sortable: true
    },
    {
      key: :updated_at,
      label: "Updated At",
      type: :datetime,
      sortable: true
    },
    {
      key: :actions,
      label: "Actions",
      type: :custom,
      align: :right,
      render: ->(metadatum) {
        content_tag(:div, class: "flex items-center justify-end gap-3") do
          safe_join([
            link_to(metadatum_path(metadatum), class: "text-actionButton hover:text-textMuted transition-colors", title: "View") do
              content_tag(:span, "", class: "icon icon-sm icon-view")
            end,
            link_to(edit_metadatum_path(metadatum), class: "text-actionButton hover:text-textMuted transition-colors", title: "Edit") do
              content_tag(:span, "", class: "icon icon-sm icon-edit")
            end,
            button_to(metadatum_path(metadatum), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this metadata?" }, class: "text-actionButton hover:text-textMuted transition-colors", title: "Delete", form: { class: "inline-flex items-center" }) do
              content_tag(:span, "", class: "icon icon-sm icon-trash")
            end
          ])
        end
      }
    }
  ]
%>

  <%= render "shared/table/table",
      collection: @metadata,
      columns: columns,
      ransack: @q,
      pagy: @pagy,
      empty_message: "No metadata found",
      empty_action: { label: "Create Metadata", path: new_metadatum_path }
  %>
</div>
