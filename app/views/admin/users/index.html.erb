<%= render partial: "admin/shared/table_header", locals: {
  title: "Users",
  icon_path: "menu/users.svg",
  current_page: :index,
  action_buttons: policy(User).create? ? [{
    label: "New User",
    path: new_user_path,
    variant: :default,
    color: :primary,
    size: :base
  }] : []
} %>

<%# Card wrapper for filter panel and table %>
<div class="rounded-lg bg-backgroundPrimary border border-borderPrimary overflow-hidden">
  <%# Filter Panel %>
  <%
    filters = [
      { key: :email, label: "Email", type: :text, placeholder: "Search by email..." },
      { key: :created_at, label: "Created Date", type: :date_range }
    ]
    # Add super admin filters for super admins only
    if policy(User).see_super_admin_column?
      filters.insert(1, { key: :super_admin, label: "Super Admin", type: :select, collection: @filter_super_admin })
      if @filter_companies.present?
        filters.insert(1, { key: :current_company_id, label: "Company", type: :select, collection: @filter_companies })
      end
    end
  %>
  <%= render "shared/filter/filter_panel",
      ransack: @q,
      filters: filters,
      form_url: users_path %>

  <%
    columns = [
      {
        key: :id,
        label: "ID",
        type: :number,
        sortable: true
      },
      {
        key: :email,
        label: "Email",
        type: :link,
        link_path: ->(user) { user_path(user) },
        link_class: "text-primary hover:underline",
        sortable: true
      },
      policy(User).see_company_column? ? {
        key: :company,
        label: "Company",
        type: :custom,
        sortable: false,
        render: ->(user) {
          user.company ? company_link_with_tier(user.company) : content_tag(:span, "—", class: "text-textMuted")
        }
      } : nil,
      policy(User).see_super_admin_column? ? {
        key: :super_admin,
        label: "Super Admin",
        type: :status_tag,
        sortable: true,
        value: ->(user) { user.super_admin? }
      } : nil,
      {
        key: :created_at,
        label: "Created On",
        type: :datetime,
        sortable: true
      },
      {
        key: :actions,
        label: "Actions",
        type: :custom,
        align: :right,
        render: ->(user) {
          content_tag(:div, class: "flex items-center justify-end gap-3 min-w-[80px]") do
            links = []

            # Impersonate button (super_admin only, not for super_admins or self)
            if policy(user).impersonate?
              links << button_to(impersonation_path(id: user.id),
                method: :post,
                class: "text-actionButton hover:text-textMuted transition-colors cursor-pointer",
                title: "Login as #{user.email}",
                form: { class: "inline-flex items-center", data: { turbo_frame: "_top" } }) do
                  content_tag(:span, "", class: "icon icon-sm icon-arrow-right-end-on-rectangle")
                end
            end

            if policy(user).update?
              links << link_to(edit_user_path(user), class: "text-actionButton hover:text-textMuted transition-colors", title: "Edit") do
                content_tag(:span, "", class: "icon icon-sm icon-edit")
              end
            end
            if policy(user).destroy?
              links << button_to(user_path(user), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this user?" }, class: "text-actionButton hover:text-textMuted transition-colors cursor-pointer", title: "Delete", form: { class: "inline-flex items-center" }) do
                content_tag(:span, "", class: "icon icon-sm icon-trash")
              end
            end
            safe_join(links)
          end
        }
      }
    ]
  %>

  <%= render "shared/table/table",
      collection: @users,
      columns: columns.compact,
      ransack: @q,
      pagy: @pagy,
      empty_message: "No users found",
      empty_action: policy(User).create? ? { label: "Create User", path: new_user_path } : nil
  %>
</div>
