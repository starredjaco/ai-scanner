<div class="bg-white dark:bg-zinc-900 rounded-lg shadow-sm border border-gray-100 dark:border-zinc-700 p-3 lg:p-4 flex flex-col">
  <div class="flex items-center gap-2 mb-3">
    <h3 class="text-white font-sans text-base font-normal">Average ASR</h3>
    <%= render 'shared/info_tooltip', aria_label: 'Information about Average ASR', content: t('dashboard.tooltips.average_asr') %>
  </div>
  <div class="flex items-center justify-between flex-grow">
    <span data-dashboard-target="totalHits3" class="stat-value"></span>
    <div data-dashboard-target="sparklineChart3" class="w-16 h-8 sm:w-20 sm:h-10 shrink-0" aria-label="Average Scan Score trend chart"></div>
  </div>
</div>
