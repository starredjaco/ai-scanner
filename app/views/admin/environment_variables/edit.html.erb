<%
  action_buttons = [
    { label: "Delete", path: environment_variable_path(@environment_variable), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this environment variable?" }, variant: :default, color: :gray, size: :base, icon: "icon-trash" }
  ]

  # Build title based on whether it's a global or target-specific variable
  title_prefix = @environment_variable.target ? "Edit ENV Var" : "Edit Global ENV Var"
%>
<%= render partial: "admin/shared/show_header", locals: { title: "#{title_prefix}: #{@environment_variable.env_name}", action_buttons: action_buttons } %>

<div class="py-6">
  <%= render "form", environment_variable: @environment_variable %>
</div>
