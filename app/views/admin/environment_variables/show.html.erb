<%
  action_buttons = [
    { label: "Edit", path: edit_environment_variable_path(@environment_variable), variant: :default, color: :gray, size: :base, icon: "icon-edit" },
    { label: "Delete", path: environment_variable_path(@environment_variable), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this environment variable?" }, variant: :default, color: :gray, size: :base, icon: "icon-trash" }
  ]

  # Build title based on whether it's a global or target-specific variable
  title_prefix = @environment_variable.target ? "ENV Var" : "Global ENV Var"
%>
<%= render partial: "admin/shared/show_header", locals: { title: "#{title_prefix}: #{@environment_variable.env_name}", action_buttons: action_buttons } %>

<div class="py-6">
  <div class="rounded-lg bg-backgroundPrimary border border-borderPrimary p-6">
    <table class="w-full">
      <tbody class="divide-y divide-borderPrimary">
        <tr>
          <th class="py-3 pr-4 text-left text-sm font-medium text-contentSecondary w-1/4">ID</th>
          <td class="py-3 text-sm text-contentPrimary"><%= @environment_variable.id %></td>
        </tr>
        <tr>
          <th class="py-3 pr-4 text-left text-sm font-medium text-contentSecondary w-1/4">Target</th>
          <td class="py-3 text-sm text-contentPrimary">
            <% if @environment_variable.target %>
              <%= link_to @environment_variable.target.name, target_path(@environment_variable.target), class: "text-primary hover:underline" %>
            <% else %>
              <span class="text-contentTertiary">Global</span>
            <% end %>
          </td>
        </tr>
        <tr>
          <th class="py-3 pr-4 text-left text-sm font-medium text-contentSecondary w-1/4">Name</th>
          <td class="py-3 text-sm text-contentPrimary"><code class="bg-backgroundSecondary px-2 py-1 rounded text-sm"><%= @environment_variable.env_name %></code></td>
        </tr>
        <tr>
          <th class="py-3 pr-4 text-left text-sm font-medium text-contentSecondary w-1/4">
            Value
            <span class="ml-1 status-tag encrypted">Encrypted</span>
          </th>
          <td class="py-3 text-sm text-contentPrimary">
            <div class="flex items-center" data-controller="value-masking">
              <div class="inline-grid">
                <code class="bg-backgroundSecondary px-2 py-1 rounded text-sm col-start-1 row-start-1" data-value-masking-target="mask">••••••••</code>
                <code class="bg-backgroundSecondary px-2 py-1 rounded text-sm col-start-1 row-start-1 invisible break-all" data-value-masking-target="value"><%= @environment_variable.env_value %></code>
              </div>
              <button type="button" class="ml-2 text-contentTertiary hover:text-contentPrimary text-sm shrink-0" title="Show/Hide value" data-action="value-masking#toggle" data-value-masking-target="icon">👁</button>
            </div>
          </td>
        </tr>
        <tr>
          <th class="py-3 pr-4 text-left text-sm font-medium text-contentSecondary w-1/4">Created On</th>
          <td class="py-3 text-sm text-contentPrimary"><%= @environment_variable.created_at.strftime("%B %d, %Y at %I:%M %p") %></td>
        </tr>
        <tr>
          <th class="py-3 pr-4 text-left text-sm font-medium text-contentSecondary w-1/4">Updated At</th>
          <td class="py-3 text-sm text-contentPrimary"><%= @environment_variable.updated_at.strftime("%B %d, %Y %H:%M") %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
