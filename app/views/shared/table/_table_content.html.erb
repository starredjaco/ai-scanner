<%# Table content (used by main table partial) %>

<% if collection.empty? %>
  <%= render "shared/table/empty_state", message: empty_message, action: empty_action %>
<% else %>
  <div class="overflow-x-auto">
    <table class="min-w-full" id="<%= table_id %>">
      <thead class="bg-backgroundPrimary border-b border-borderPrimary">
        <tr>
          <% if has_batch_actions %>
            <th class="px-4 py-3 w-12">
              <input type="checkbox"
                     data-batch-select-target="selectAll"
                     data-action="change->batch-select#toggleAll">
            </th>
          <% end %>
          <% columns.each do |column| %>
            <% next if column[:type] == :checkbox %>
            <th class="px-4 py-3 text-xs font-medium text-textMuted uppercase tracking-wider <%= column[:header_class] || '' %> <%= column[:align] == :right ? 'text-right' : (column[:align] == :center ? 'text-center' : 'text-left') %>">
              <div class="flex items-center gap-1.5 <%= column[:align] == :right ? 'justify-end' : (column[:align] == :center ? 'justify-center' : '') %>">
                <%= table_sort_header(column, ransack: ransack) %>
                <% if column[:header_suffix] %>
                  <%= column[:header_suffix].call %>
                <% end %>
              </div>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody class="bg-backgroundPrimary divide-y divide-borderPrimary">
        <% collection.each do |item| %>
          <tr class="hover:bg-zinc-800/50 transition-colors">
            <% if has_batch_actions %>
              <td class="px-4 py-3">
                <%= check_box_tag "ids[]", item.id, false,
                    data: { batch_select_target: "checkbox", action: "change->batch-select#toggle" } %>
              </td>
            <% end %>
            <% columns.each do |column| %>
              <% next if column[:type] == :checkbox %>
              <td class="px-4 py-3 text-sm text-textMuted <%= column[:cell_class] || '' %> <%= column[:align] == :right ? 'text-right' : (column[:align] == :center ? 'text-center' : '') %>">
                <% if column[:render] %>
                  <%= column[:render].call(item) %>
                <% else %>
                  <%= table_render_cell(item, column, ransack: ransack) %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
