# Scanner Application Environment Configuration Example
# Copy this file to .env and update with your actual values

# Rails Configuration
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=generate_me_with_openssl_rand_hex_64
SOLID_QUEUE_IN_PUMA=true
RUBY_YJIT_ENABLE=1  # Enable YJIT for ~2x performance boost (Ruby 3.3+)

# Application Port
PORT=80  # Host port the scanner is accessible on (container always listens on 80)

# SSL Configuration
ASSUME_SSL=false  # Set to true in production

# PostgreSQL Configuration
# PostgreSQL runs as a separate container service (docker-compose postgres service)
# POSTGRES_PASSWORD is required for production compose (docker-compose.yml)
# For managed PostgreSQL (AWS RDS, Azure, Google Cloud SQL), also set POSTGRES_HOST
POSTGRES_USER=scanner                  # Database username
POSTGRES_PASSWORD=change_me            # Required for production docker-compose.yml
# POSTGRES_HOST=postgres               # Hostname (default: postgres docker service name)
# POSTGRES_PORT=5432                   # Port number (default: 5432)

# SSL Configuration (for external PostgreSQL)
# POSTGRES_SSL_MODE=prefer             # Options: disable, allow, prefer, require, verify-ca, verify-full
                                       # disable    = No SSL
                                       # allow      = Try non-SSL first, then SSL
                                       # prefer     = Try SSL first, then non-SSL (default)
                                       # require    = SSL required, no certificate verification
                                       # verify-ca  = SSL required, verify server certificate
                                       # verify-full = SSL required, verify server certificate and hostname

# SSL Certificate Files (optional, for verify-ca or verify-full modes)
# POSTGRES_SSL_CERT=/path/to/client-cert.pem     # Client certificate
# POSTGRES_SSL_KEY=/path/to/client-key.pem       # Client private key
# POSTGRES_SSL_ROOT_CERT=/path/to/ca-cert.pem    # CA certificate

# Connection Pool Settings (optional)
# POSTGRES_POOL_SIZE=5                 # Max connections per process (default: 5)
# POSTGRES_POOL_TIMEOUT=5000           # Connection checkout timeout in ms (default: 5000)

# Database Names (optional, defaults shown)
# POSTGRES_PRIMARY_DB=scanner_production        # Main application database
# POSTGRES_QUEUE_DB=scanner_production_queue    # Solid Queue database
# POSTGRES_CACHE_DB=scanner_production_cache    # Rails cache database
# POSTGRES_CABLE_DB=scanner_production_cable    # ActionCable database

# === Alternative: DATABASE_URL Configuration (Recommended for Cloud Deployments) ===
# Standard PostgreSQL connection URL format
# Takes precedence over individual POSTGRES_* variables above
# Automatically creates queue/cache/cable databases by appending suffixes to the database name
#
# Format: postgresql://username:password@hostname:port/database_name?query_params
#
# Example for PostgreSQL via docker-compose service:
# DATABASE_URL=postgresql://scanner:mypassword@postgres.example.com:5432/scanner_production
#
# Example with SSL (AWS RDS, Azure, Google Cloud SQL):
# DATABASE_URL=postgresql://scanner:mypassword@mydb.us-east-1.rds.amazonaws.com:5432/scanner_production?sslmode=require
#
# URL Encoding for Special Characters in Password:
# @ → %40, ! → %21, # → %23, $ → %24, % → %25
# Example password "p@ss!w0rd" becomes: postgresql://scanner:p%40ss%21w0rd@host:5432/dbname
#
# Multi-Database Support:
# - Primary database: Uses DATABASE_URL directly
# - Queue database: Auto-generated as scanner_production_queue (or override with DATABASE_QUEUE_URL)
# - Cache database: Auto-generated as scanner_production_cache (or override with DATABASE_CACHE_URL)
# - Cable database: Auto-generated as scanner_production_cable (or override with DATABASE_CABLE_URL)
#
# Individual Override URLs (optional):
# DATABASE_QUEUE_URL=postgresql://scanner:password@different-host:5432/custom_queue
# DATABASE_CACHE_URL=postgresql://scanner:password@different-host:5432/custom_cache
# DATABASE_CABLE_URL=postgresql://scanner:password@different-host:5432/custom_cable

# Admin Seed User
# These control the initial admin account created by `rails db:prepare`
# ADMIN_EMAIL=admin@example.com
# ADMIN_INITIAL_PASSWORD=password

# External Services (optional, configured via Settings page in the UI)
# SIEM integration (Splunk, Rsyslog) is configured through the admin UI, not env vars.

# Report Retention
# RETENTION_DAYS=90                    # Days to keep reports (default: 90)

# Logging
# RAILS_LOG_LEVEL=info                 # Log level: debug, info, warn, error (default: info)

# Microsoft Clarity Analytics (Demo Only)
# Clarity provides heatmaps and session recordings for UX analysis
# Only set this on demo environments - do NOT set for on-prem or customer deployments
# CLARITY_PROJECT_ID=your_clarity_project_id

# --- Vendored Engine (optional) ---
# These are only needed when running with a vendored engine that adds OAuth.
# DEPLOYMENT_TYPE=custom
# OAUTH_CLIENT_ID=your_oauth_client_id
# OAUTH_CLIENT_SECRET=your_oauth_client_secret
# OAUTH_SITE=https://auth.example.com
