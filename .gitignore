# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Local environment files (contain secrets)
.env
.env.local
.env.*.local

# Local Gemfile overrides (dev-only engine loading)
Gemfile.local

# Private plugin repos (sibling directories used in development)
garak-0din-plugins/

# Mac
.DS_Store

# Python
__pycache__/
*.pyc

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# PostgreSQL migration files
storage/database/postgresql/
storage/.postgres_migration_complete

# Ollama model storage (large files)
/storage/ollama/models/*
!/storage/ollama/models/.keep
!/storage/ollama/scripts

# Screenshots from browser automation
/storage/screenshots/*
!/storage/screenshots/.keep

/public/assets

# Ignore master key and encrypted credentials.
/config/master.key
/config/credentials.yml.enc
/config/credentials/

/.idea

/app/assets/builds/*
!/app/assets/builds/.keep

/node_modules
/coverage

# Probe signing output files
/private_scripts/probes/output
engines/*/private_scripts/

# Claude AI settings
/.claude/settings.local.json

# act (GitHub Actions local runner) configuration
/.actrc
/.secrets

# Cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/
cypress/.e2e/

# Releases
RELEASE_NOTES.md

# Claude Flow generated files
.claude/settings.local.json
bin/rspec-docker

# ralphex progress logs
.ralphex/progress/
docs/plans/

# Docusaurus docs site build artifacts
docs-site/build/
docs-site/node_modules/
docs-site/.docusaurus/
